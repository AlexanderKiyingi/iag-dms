# Local direct — memory store only (full platform: see config/.env.example).
# Bearer JWT with aud=iag.dms is still required; spin up iag-authentication or
# point JWT_ISSUER/JWKS_URL at a running instance.
PORT=4010
STORE_MODE=memory
JWT_ISSUER=http://localhost:3001
JWKS_URL=http://127.0.0.1:3001/.well-known/jwks.json
AUDIENCE=iag.dms

# Optional — proxy finance hub from iag-finance (service-to-service).
# FINANCE_URL=http://127.0.0.1:3006
# SERVICE_CLIENT_SECRET=...  # client credentials for iag-dms → iag.finance
