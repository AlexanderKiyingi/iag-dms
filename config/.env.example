# Service
SERVICE_NAME=dms
ENVIRONMENT=development
PORT=4010
LOG_LEVEL=info
# LOG_FORMAT=json  # use plain text when unset

# Hard cutover: every request must carry a Bearer JWT with aud=iag.dms.
# AUTH_MODE and GATEWAY_INTERNAL_SECRET no longer exist.
GATEWAY_API_PREFIX=/api/v1/dms
PUBLIC_API_URL=http://localhost:8080
JWT_ISSUER=http://localhost:3001
JWKS_URL=http://localhost:3001/.well-known/jwks.json
AUDIENCE=iag.dms

# Outbound service-account credentials
SERVICE_CLIENT_ID=iag-dms
SERVICE_CLIENT_SECRET=dev-dms-secret-bootstrap
AUTH_TOKEN_URL=http://localhost:3001/oauth/token

# Database (STORE_MODE=memory bypasses DATABASE_URL for local quick-start)
DATABASE_URL=postgres://svc_iag_dms:iag_dms_dev@localhost:5432/iag_platform?sslmode=disable
# STORE_MODE=memory
AUTO_MIGRATE=true
SEED_ON_EMPTY=true

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional finance upstream (service-account token to iag.finance)
# FINANCE_URL=http://localhost:8080/api/v1/finance

# Kafka — operations publish (outbox) + commercial consumer (optional)
# EVENT_BUS_ENABLED=true
# KAFKA_BROKERS=localhost:19092
# CONSUMER_ENABLED=true
# CONSUMER_TOPIC=iag.commercial
# CONSUMER_GROUP_ID=iag-dms

# Optional bind override (PORT takes precedence over ADDR)
# ADDR=:4010
