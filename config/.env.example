SERVICE_NAME=dms
PORT=4010
LOG_LEVEL=info

# Hard cutover: every request must carry a Bearer JWT with aud=iag.dms.
# AUTH_MODE and GATEWAY_INTERNAL_SECRET no longer exist.
GATEWAY_API_PREFIX=/api/v1/dms
PUBLIC_API_URL=http://localhost:8080
JWT_ISSUER=http://localhost:3001
JWKS_URL=http://localhost:3001/.well-known/jwks.json
AUDIENCE=iag.dms
SERVICE_CLIENT_ID=iag-dms
SERVICE_CLIENT_SECRET=dev-dms-secret-bootstrap
AUTH_TOKEN_URL=http://localhost:3001/oauth/token

DATABASE_URL=postgres://svc_iag_dms:iag_dms_dev@localhost:5432/iag_platform?sslmode=disable
AUTO_MIGRATE=true
SEED_ON_EMPTY=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# EVENT_BUS_ENABLED=true
# KAFKA_BROKERS=localhost:9092
# CONSUMER_ENABLED=true
# CONSUMER_TOPIC=iag.commercial
# CONSUMER_GROUP_ID=iag-dms
