# Production — run migrations separately; never seed or auto-migrate in-process.
ENVIRONMENT=production
PORT=4010
LOG_LEVEL=info
LOG_FORMAT=json

AUTH_MODE=jwt
JWT_ISSUER=https://auth.example.com
JWKS_URL=https://auth.example.com/.well-known/jwks.json
AUDIENCE=iag.dms
SERVICE_CLIENT_ID=iag-dms
SERVICE_CLIENT_SECRET=replace-with-secret-store-value-min-16-chars
AUTH_TOKEN_URL=https://auth.example.com/oauth/token

DATABASE_URL=postgres://svc_iag_dms:SECRET@pgbouncer:6432/iag_platform?sslmode=require
AUTO_MIGRATE=false
SEED_ON_EMPTY=false

GATEWAY_API_PREFIX=/api/v1/dms
PUBLIC_API_URL=https://api.example.com
ALLOWED_ORIGINS=https://app.example.com

OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317
EVENT_BUS_ENABLED=true
KAFKA_BROKERS=redpanda:9092
CONSUMER_ENABLED=true
CONSUMER_TOPIC=iag.commercial
CONSUMER_GROUP_ID=iag-dms
